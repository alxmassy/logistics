# =============================================================================
# Logistics Platform — Environment Configuration
# Copy this file to .env and adjust values for your environment.
# =============================================================================

# --- Kafka / Redpanda ---
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Topic Configuration ---
TELEMETRY_TOPIC=shipment-telemetry
THREAT_TOPIC=threat-signals
TELEMETRY_PARTITIONS=6
THREAT_PARTITIONS=3
ANOMALY_ALERTS_TOPIC=anomaly-alerts
ANOMALY_ALERTS_PARTITIONS=3
OPTIMIZATION_REQUESTS_TOPIC=optimization-requests
OPTIMIZATION_REQUESTS_PARTITIONS=3

# --- Generator Defaults ---
GENERATOR_RATE_PER_SEC=100
GENERATOR_NUM_SHIPMENTS=50
FAILURE_INJECTION_RATIO=0.1

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Context Assembly Consumer ---
CONSUMER_GROUP_ID=context-assembly

# --- Flink (used inside Docker container only) ---
FLINK_KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
FLINK_WATERMARK_TOLERANCE_SECONDS=120
FLINK_INTERVAL_JOIN_MINUTES=10
THREAT_TTL_S=600
FLINK_TELEMETRY_GROUP_ID=flink-collision-telemetry
FLINK_THREAT_GROUP_ID=flink-collision-threats
